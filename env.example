# Public app configuration
NEXT_PUBLIC_CDP_PROJECT_ID=example-id
# Include the protocol, e.g. http://localhost:3000
BASE_URL=http://localhost:3000

# Agent wallet + AgentKit
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Optional custom RPC override for AgentKit/x402
CDP_AGENT_RPC_URL=

# x402 seller configuration
X402_FACILITATOR_URL=https://x402.org/facilitator

# LLM Gateway (OpenAI-compatible)
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_BASE_URL=https://llm-gateway.cbhq.net/v1
LLM_GATEWAY_MODEL=gpt-4o-mini
CHAT_LLM_MODEL=gpt-4.5

# Optional Coinbase market data credentials
# If omitted, DEXter Hub falls back to the public Coinbase Exchange ticker.
COINBASE_API_KEY_ID=
COINBASE_API_KEY_SECRET=

# Neon Postgres (via Vercel)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Legacy variable fallbacks still supported by the app:
# CDP_API_KEY / CDP_API_SECRET
# CDP_API_ID / CDP_API_SECRET_2
# OPENAI_API_KEY / OPENAI_MODEL
